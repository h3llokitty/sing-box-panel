# Справочный шаблон. install.sh спросит эти значения интерактивно
# и сам создаст /etc/sing-box/vpn-panel.env — редактировать этот файл не нужно,
# разве что для ручной правки уже существующей установки.

A_IP="ВАШ_IP_СЕРВЕРА_A"
