ACME_EMAIL="you@example.com"
WG_PORT=51820
WG_NET="10.10.0"
HY2_PORT=443
B_DOMAIN="сервер-b.example.com"
B_PORT=443
B_PASS="ПАРОЛЬ_HY2_НА_СЕРВЕРЕ_B"
PROFILE_HOST="ваш-домен.example.com"
PROFILE_PORT=8443
VLESS_PORT=443
VLESS_DEST="ozon.ru"
VLESS_SNI="ozon.ru"
AVAILABLE_PROXY_TYPES="hy2 vless"
